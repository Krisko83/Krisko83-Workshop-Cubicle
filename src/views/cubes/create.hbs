{{ setTitle 'Create Cube'}}

<h1>Create</h1>
<div class="form">
  <form method="POST">
    <label for="name">Name</label>
    <input type="text" id="name" name="name" value="{{name}}">
    <label for="name">Description</label>
    <textarea id="name" name="description">{{description}}</textarea>
    <label for="image">ImageUrl</label>
    <input type="text" id="image" name="imageUrl" value="{{imageUrl}}">
    <label for="difficulty">Difficulty</label>
    <select id="difficulty" name="difficultyLevel">
      {{#each options}}
      <option value="{{value}}" {{isSelected}}>{{label}}</option>  
      {{/each}}   
    </select>
    <input type="submit" value="Create">
  </form>
</div>